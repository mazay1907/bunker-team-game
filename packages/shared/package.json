{
  "name": "@bunker/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types for Bunker Team Game",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
